{
  "hooks": {
    "SubagentStart": [
      {
        "type": "command",
        "command": ".github/scripts/subagent-context.sh",
        "linux": ".github/scripts/subagent-context.sh",
        "timeout": 10
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": ".github/scripts/subagent-cleanup.sh",
        "linux": ".github/scripts/subagent-cleanup.sh",
        "timeout": 10
      }
    ]
  }
}
